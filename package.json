{
  "name": "file-relay-hub",
  "version": "0.1.0",
  "description": "Temporary file relay service with expiring share links, admin-managed file list, and disk safety guardrails.",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "npm run build"
  },
  "keywords": [
    "file-sharing",
    "file-relay",
    "fastify",
    "typescript",
    "upload",
    "temporary-link"
