  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XingCheng3/file-relay-hub.git"
  },
  "bugs": {
    "url": "https://github.com/XingCheng3/file-relay-hub/issues"
  },
  "homepage": "https://github.com/XingCheng3/file-relay-hub#readme",
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
